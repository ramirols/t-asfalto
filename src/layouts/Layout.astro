---
const {
	title = "T - Asfalto",
	description = "Venta de asfalto RC-250 y productos bituminosos en Perú",
} = Astro.props;

import "../styles/global.css";
import Header from "../components/Header.jsx";
import Footer from "../components/Footer.astro";
import AosClient from "../components/AosClient.jsx";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		<link rel="icon" href="/favicon.svg" />
		<!-- Google Font: Inter -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
		<!-- SEO -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://t-asfalto.vercel.app/" />
		<meta property="og:image" content="/images/preview.jpg" />
		<link rel="canonical" href="https://t-asfalto.vercel.app/" />
		<meta name="author" content="T-Asfalto Perú" />
		<meta name="theme-color" content="#FFDF20" />
		<meta property="og:locale" content="es_PE" />
		<meta property="og:site_name" content="T-Asfalto Perú" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="/images/preview.jpg" />
	</head>

	<body>
		<Header client:only="react" />
		<div class="pt-[72px] flex flex-col relative overflow-x-hidden">
			<slot />
		</div>
		<Footer />
		<AosClient client:only="react" />
	</body>
</html>

<style is:global>
	@import "tailwindcss";

	@theme {
		--color-primary: #FFDF20;
		--color-primary-hover: #e6c800;
		--color-secondary: #C62828;
		--color-text: #1b1b1b;
		--color-dark: #1a1a1a;
		--color-darker: #111111;
		--color-light: #f5f5f5;
		--color-accent-red: #C62828;
	}

	html {
		margin: 0;
		width: 100%;
		height: 100%;
		scroll-behavior: smooth;
		font-family: 'Inter', system-ui, -apple-system, sans-serif;
	}

	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		overflow-x: hidden;
	}
</style>
