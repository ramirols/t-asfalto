---

---

<section id="contacto" class="py-20 md:py-28 bg-white">
	<div class="max-w-7xl mx-auto px-6 lg:px-8">
		<div class="text-center mb-16">
			<p class="text-xs font-bold tracking-[0.35em] uppercase text-[#FFDF20] mb-3" data-aos="fade-up">— Escríbenos —</p>
			<h2
				class="text-4xl md:text-5xl lg:text-6xl font-black text-[#1a1a1a] leading-tight"
				data-aos="fade-up"
				data-aos-delay="100"
			>
				Contáctanos
			</h2>
			<p class="text-gray-500 mt-4 max-w-2xl mx-auto text-lg" data-aos="fade-up" data-aos-delay="200">
				Envíanos tu consulta o cotización y nuestro equipo te responderá
				lo antes posible.
			</p>
		</div>

		<div class="grid lg:grid-cols-2 gap-12 items-start">
			<!-- Contact Info -->
			<div data-aos="fade-right" data-aos-delay="200">
				<h3 class="text-2xl font-bold text-[#1a1a1a] mb-8">
					Información de Contacto
				</h3>
				<div class="space-y-6">
					<a href="https://maps.google.com/?q=Av.+Industrial+345+Lima+Peru" target="_blank" rel="noopener" class="flex items-start gap-4 group p-4 rounded-xl hover:bg-[#f5f5f5] transition-colors">
						<div class="w-12 h-12 rounded-xl bg-[#FFDF20] flex items-center justify-center shrink-0 group-hover:scale-110 group-hover:shadow-[0_0_20px_rgba(255,223,32,0.4)] transition-all duration-300">
							<svg class="w-5 h-5 text-[#1a1a1a]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
						</div>
						<div>
							<p class="font-bold text-[#1a1a1a] text-lg">Dirección</p>
							<p class="text-gray-500">Av. Industrial 345, Lima, Perú</p>
						</div>
					</a>

					<a href="tel:+51987654321" class="flex items-start gap-4 group p-4 rounded-xl hover:bg-[#f5f5f5] transition-colors">
						<div class="w-12 h-12 rounded-xl bg-[#FFDF20] flex items-center justify-center shrink-0 group-hover:scale-110 group-hover:shadow-[0_0_20px_rgba(255,223,32,0.4)] transition-all duration-300">
							<svg class="w-5 h-5 text-[#1a1a1a]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
						</div>
						<div>
							<p class="font-bold text-[#1a1a1a] text-lg">Teléfono</p>
							<p class="text-gray-500 text-lg">+51 987 654 321</p>
						</div>
					</a>

					<a href="mailto:ventas@t-asfalto.pe" class="flex items-start gap-4 group p-4 rounded-xl hover:bg-[#f5f5f5] transition-colors">
						<div class="w-12 h-12 rounded-xl bg-[#FFDF20] flex items-center justify-center shrink-0 group-hover:scale-110 group-hover:shadow-[0_0_20px_rgba(255,223,32,0.4)] transition-all duration-300">
							<svg class="w-5 h-5 text-[#1a1a1a]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
						</div>
						<div>
							<p class="font-bold text-[#1a1a1a] text-lg">Correo</p>
							<p class="text-gray-500 text-lg">ventas@t-asfalto.pe</p>
						</div>
					</a>
				</div>

				<div class="mt-8 rounded-xl overflow-hidden shadow-lg border border-gray-100" data-aos="fade-up" data-aos-delay="400">
					<iframe
						src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3900.837239151133!2d-77.0427541!3d-12.1309447!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9105c88a9a0b4e8d%3A0x7b7dbe2b6a9e55db!2sLima%2C%20Per%C3%BA!5e0!3m2!1ses!2spe!4v1696000000000!5m2!1ses!2spe"
						width="100%"
						height="240"
						allowfullscreen=""
						loading="lazy"
						referrerpolicy="no-referrer-when-downgrade"
						class="grayscale hover:grayscale-0 transition-all duration-500"></iframe>
				</div>
			</div>

			<!-- Form -->
			<div class="bg-[#f5f5f5] rounded-2xl p-8 md:p-10 shadow-md border border-gray-100" data-aos="fade-left" data-aos-delay="300">
				<h3 class="text-2xl font-bold text-[#1a1a1a] mb-2">
					Escríbenos
				</h3>
				<p class="text-gray-500 text-sm mb-8">Completa el formulario y te responderemos a la brevedad.</p>

				<form
					action="https://formspree.io/f/tu-endpoint"
					method="POST"
					class="space-y-5"
				>
					<div>
						<input
							placeholder="Tu nombre completo"
							id="nombre"
							type="text"
							required
							class="w-full rounded-xl border border-gray-200 bg-white px-5 py-4 text-[#1a1a1a] placeholder:text-gray-400 focus:ring-2 focus:ring-[#FFDF20] focus:border-[#FFDF20] outline-none transition-all duration-300"
						/>
					</div>

					<div>
						<input
							placeholder="Tu correo electrónico"
							id="email"
							name="email"
							type="email"
							required
							class="w-full rounded-xl border border-gray-200 bg-white px-5 py-4 text-[#1a1a1a] placeholder:text-gray-400 focus:ring-2 focus:ring-[#FFDF20] focus:border-[#FFDF20] outline-none transition-all duration-300"
						/>
					</div>

					<div>
						<input
							placeholder="Tu número de teléfono"
							id="telefono"
							name="telefono"
							type="tel"
							class="w-full rounded-xl border border-gray-200 bg-white px-5 py-4 text-[#1a1a1a] placeholder:text-gray-400 focus:ring-2 focus:ring-[#FFDF20] focus:border-[#FFDF20] outline-none transition-all duration-300"
						/>
					</div>

					<div>
						<textarea
							id="mensaje"
							name="mensaje"
							placeholder="Describe tu proyecto o consulta"
							rows="5"
							required
							class="w-full rounded-xl border border-gray-200 bg-white px-5 py-4 text-[#1a1a1a] placeholder:text-gray-400 focus:ring-2 focus:ring-[#FFDF20] focus:border-[#FFDF20] outline-none transition-all duration-300 resize-none"
						></textarea>
					</div>

					<button
						type="submit"
						class="w-full bg-[#FFDF20] hover:bg-[#e6c800] text-[#1a1a1a] font-bold py-4 rounded-xl transition-all duration-300 cursor-pointer text-base uppercase tracking-wider hover:shadow-[0_0_25px_rgba(255,223,32,0.35)] hover:-translate-y-0.5"
					>
						Enviar Mensaje
					</button>
				</form>
			</div>
		</div>
	</div>
</section>