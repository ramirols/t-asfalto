---
import imageCard1 from "../assets/images/image-card-1.png";
import imageCard2 from "../assets/images/image-card-1.png";
import imageCard3 from "../assets/images/image-card-1.png";

const servicios = [
  {
    title: "Pistas",
    description: "Construcción y asfaltado de pistas vehiculares con materiales de primera calidad.",
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l5.447 2.724A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg>`,
  },
  {
    title: "Recapeo",
    description: "Renovación de carpetas asfálticas desgastadas para mayor durabilidad y seguridad vial.",
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>`,
  },
  {
    title: "Imprimación",
    description: "Aplicación técnica de imprimantes asfálticos para adherencia óptima de capas de rodadura.",
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>`,
  },
  {
    title: "Slurry",
    description: "Tratamiento superficial con mezcla de emulsión y agregado fino para sellado y protección.",
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>`,
  },
  {
    title: "Asfalto Reciclado",
    description: "Soluciones sostenibles con reutilización de mezclas asfálticas recuperadas.",
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>`,
  },
  {
    title: "Señalización de Vías",
    description: "Demarcación y señalización vial horizontal para seguridad en carreteras y calles.",
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>`,
  },
];
---

<section id="servicios" class="py-20 md:py-28 bg-[#1a1a1a] relative overflow-hidden">
	<!-- Background pattern -->
	<div class="absolute inset-0 bg-[linear-gradient(rgba(255,223,32,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,223,32,0.03)_1px,transparent_1px)] bg-[size:40px_40px]"></div>
	
	<div class="relative max-w-7xl mx-auto px-6 lg:px-8">
		<div class="text-center mb-16">
			<p class="text-xs font-bold tracking-[0.35em] uppercase text-[#FFDF20] mb-3" data-aos="fade-up">— Nuestros Servicios —</p>
			<h2
				class="text-4xl md:text-5xl lg:text-6xl font-black text-white leading-tight"
				data-aos="fade-up"
				data-aos-delay="100"
			>
				Soluciones <span class="bg-gradient-to-r from-[#FFDF20] to-[#e6c800] bg-clip-text text-transparent">Profesionales</span>
			</h2>
			<p
				class="text-white/60 mt-5 max-w-2xl mx-auto text-lg"
				data-aos="fade-up"
				data-aos-delay="200"
			>
				Ofrecemos una amplia gama de <span class="font-semibold text-[#FFDF20]">servicios especializados en asfalto</span>.
			</p>
		</div>

		<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
			{servicios.map((servicio, i) => (
				<div
					class="group relative bg-white/5 border border-white/10 rounded-xl p-7 transition-all duration-500 hover:border-[#FFDF20]/50 hover:bg-white/8 hover:-translate-y-1 hover:shadow-[0_0_30px_rgba(255,223,32,0.1)] cursor-pointer"
					data-aos="fade-up"
					data-aos-delay={String(100 + i * 100)}
				>
					<div class="w-14 h-14 rounded-xl bg-[#FFDF20]/10 border border-[#FFDF20]/30 flex items-center justify-center mb-5 text-[#FFDF20] group-hover:bg-[#FFDF20] group-hover:text-[#1a1a1a] transition-all duration-300 group-hover:shadow-[0_0_20px_rgba(255,223,32,0.3)]">
						<Fragment set:html={servicio.icon} />
					</div>
					<h3 class="text-xl font-bold text-white mb-3 tracking-wide">{servicio.title}</h3>
					<p class="text-white/60 text-sm leading-relaxed">{servicio.description}</p>
				</div>
			))}
		</div>
	</div>
</section>