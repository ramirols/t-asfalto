---
import RC250 from "../assets/images/producto-rc250.webp";
import MC30 from "../assets/images/producto-mc30.webp";
import MC70 from "../assets/images/producto-mc70.webp";
import Emulsion from "../assets/images/producto-emulsion.webp";

const productos = [
  {
    img: RC250,
    title: "Asfalto RC-250",
    tag: "Curado Rápido",
    desc: "Ideal para riegos de liga, imprimaciones y mezclas en caliente. Producto de alta adherencia y excelente desempeño vial.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z" /><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z" /></svg>`,
  },
  {
    img: MC30,
    title: "Asfalto MC-30",
    tag: "Curado Medio",
    desc: "Asfalto líquido de curado medio, perfecto para imprimaciones de bases granulares y obras de estabilización.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>`,
  },
  {
    img: MC70,
    title: "Asfalto MC-70",
    tag: "Alta Penetración",
    desc: "Recomendado para riegos de imprimación y mezclas en frío. Ofrece gran penetración y adherencia en todo tipo de superficie.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>`,
  },
  {
    img: Emulsion,
    title: "Emulsión Asfáltica",
    tag: "Sellado & Mantenimiento",
    desc: "Disponible en presentaciones catiónicas y aniónicas. Ideal para sellado, mantenimiento y riegos de adherencia.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>`,
  },
];
---

<section id="productos" class="py-20 md:py-28 bg-[#f5f5f5] relative overflow-hidden">
	<div class="absolute top-0 right-0 w-[400px] h-[400px] rounded-full bg-[#FFDF20]/5 blur-3xl pointer-events-none"></div>

	<div class="max-w-7xl mx-auto px-6 lg:px-8 relative">
		<div class="flex flex-col md:flex-row md:items-end md:justify-between mb-14 gap-6">
			<div>
				<p class="text-xs font-bold tracking-[0.35em] uppercase text-[#FFDF20] mb-3" data-aos="fade-up">— Nuestros Productos —</p>
				<h2
					class="text-4xl md:text-5xl lg:text-6xl font-black text-[#1a1a1a] leading-tight"
					data-aos="fade-up"
					data-aos-delay="100"
				>
					Productos de <span class="bg-gradient-to-r from-[#FFDF20] to-[#e6c800] bg-clip-text text-transparent">Calidad</span>
				</h2>
				<p class="text-gray-500 mt-4 max-w-xl text-lg" data-aos="fade-up" data-aos-delay="200">
					Distribuimos <span class="font-semibold text-[#1a1a1a]">asfaltos líquidos y emulsiones</span> cumpliendo estándares del MTC.
				</p>
			</div>

			<!-- Navigation arrows -->
			<div class="flex items-center gap-3" data-aos="fade-up" data-aos-delay="300">
				<button id="prod-prev" aria-label="Anterior" class="w-12 h-12 rounded-full border-2 border-[#1a1a1a]/20 flex items-center justify-center text-[#1a1a1a]/50 hover:border-[#FFDF20] hover:bg-[#FFDF20] hover:text-[#1a1a1a] transition-all duration-300 cursor-pointer">
					<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
				</button>
				<button id="prod-next" aria-label="Siguiente" class="w-12 h-12 rounded-full border-2 border-[#1a1a1a]/20 flex items-center justify-center text-[#1a1a1a]/50 hover:border-[#FFDF20] hover:bg-[#FFDF20] hover:text-[#1a1a1a] transition-all duration-300 cursor-pointer">
					<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
				</button>
			</div>
		</div>

		<!-- Carousel -->
		<div id="prod-carousel" class="flex gap-6 overflow-x-auto scroll-smooth snap-x snap-mandatory pb-4" style="scrollbar-width: none; -ms-overflow-style: none;" data-aos="fade-up" data-aos-delay="200">
			{productos.map((prod, i) => (
				<div
					class="group relative flex-shrink-0 w-[85%] sm:w-[48%] lg:w-[calc(33.333%-16px)] bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 border border-gray-100 hover:border-[#FFDF20]/30 snap-start"
				>
					<!-- Image -->
					<div class="relative aspect-[4/3] overflow-hidden">
						<img
							src={prod.img.src}
							alt={prod.title}
							class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
							loading="lazy"
						/>
						<div class="absolute inset-0 bg-gradient-to-t from-[#1a1a1a]/60 via-[#1a1a1a]/10 to-transparent"></div>

						<!-- Tag -->
						<div class="absolute top-4 left-4 bg-[#1a1a1a]/70 backdrop-blur-sm text-white text-[10px] font-bold uppercase tracking-[0.2em] px-3 py-1.5 rounded-full">
							{prod.tag}
						</div>

						<!-- Icon -->
						<div class="absolute bottom-4 right-4 w-12 h-12 rounded-xl bg-[#FFDF20] flex items-center justify-center text-[#1a1a1a] shadow-lg group-hover:scale-110 group-hover:shadow-[0_0_25px_rgba(255,223,32,0.5)] transition-all duration-300">
							<Fragment set:html={prod.icon} />
						</div>

						<!-- Title overlay on image -->
						<div class="absolute bottom-4 left-5">
							<h3 class="text-2xl font-black text-white drop-shadow-lg">{prod.title}</h3>
						</div>
					</div>

					<!-- Content -->
					<div class="p-6">
						<p class="text-gray-500 text-sm leading-relaxed mb-6">{prod.desc}</p>
						<a
							href="#contacto"
							class="inline-flex items-center gap-2 bg-[#FFDF20] hover:bg-[#e6c800] text-[#1a1a1a] font-bold text-sm py-3 px-7 rounded-lg transition-all duration-300 uppercase tracking-wider hover:shadow-[0_0_20px_rgba(255,223,32,0.35)] hover:-translate-y-0.5 group/btn"
						>
							Cotizar
							<svg class="w-4 h-4 transition-transform duration-300 group-hover/btn:translate-x-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
						</a>
					</div>

					<!-- Bottom accent line -->
					<div class="absolute bottom-0 left-0 w-0 h-1 bg-gradient-to-r from-[#FFDF20] to-[#e6c800] group-hover:w-full transition-all duration-700 ease-out"></div>
				</div>
			))}
		</div>
	</div>
</section>

<!-- Hide scrollbar + carousel navigation -->
<style>
	#prod-carousel::-webkit-scrollbar {
		display: none;
	}
</style>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		const carousel = document.getElementById('prod-carousel');
		const prevBtn = document.getElementById('prod-prev');
		const nextBtn = document.getElementById('prod-next');
		if (!carousel || !prevBtn || !nextBtn) return;

		const getScrollAmount = () => {
			const card = carousel.querySelector(':scope > div');
			if (!card) return 300;
			return card.offsetWidth + 24;
		};

		const scrollNext = () => {
			const maxScroll = carousel.scrollWidth - carousel.clientWidth;
			if (carousel.scrollLeft >= maxScroll - 10) {
				carousel.scrollTo({ left: 0, behavior: 'smooth' });
			} else {
				carousel.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
			}
		};

		prevBtn.addEventListener('click', () => {
			carousel.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
		});

		nextBtn.addEventListener('click', scrollNext);

		// Autoplay
		let autoplay = setInterval(scrollNext, 4000);

		carousel.addEventListener('mouseenter', () => clearInterval(autoplay));
		carousel.addEventListener('mouseleave', () => {
			autoplay = setInterval(scrollNext, 4000);
		});

		carousel.addEventListener('touchstart', () => clearInterval(autoplay), { passive: true });
		carousel.addEventListener('touchend', () => {
			autoplay = setInterval(scrollNext, 4000);
		}, { passive: true });
	});
</script>
