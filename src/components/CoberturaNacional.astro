---
const regiones = [
  "Lima", "Arequipa", "Cusco", "Piura", "Trujillo", "Puno",
  "Huancayo", "Ica", "Chiclayo", "Tacna", "Ayacucho", "Huaraz"
];
---

<section
    id="cobertura"
    class="py-20 md:py-28 bg-[#1a1a1a] relative overflow-hidden"
>
    <!-- Background pattern -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,223,32,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,223,32,0.03)_1px,transparent_1px)] bg-[size:40px_40px]"></div>
    <!-- Glow effect -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] rounded-full bg-[#FFDF20]/5 blur-3xl"></div>

    <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-14">
            <p class="text-xs font-bold tracking-[0.35em] uppercase text-[#FFDF20] mb-3" data-aos="fade-up">— Distribución —</p>
            <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-white leading-tight" data-aos="fade-up" data-aos-delay="100">
                Cobertura a <span class="bg-gradient-to-r from-[#FFDF20] to-[#e6c800] bg-clip-text text-transparent">Nivel Nacional</span>
            </h2>
            <p class="text-white/60 mt-5 max-w-2xl mx-auto text-lg" data-aos="fade-up" data-aos-delay="200">
                Realizamos envíos de asfalto y emulsiones bituminosas a todas las
                regiones del Perú.
            </p>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4 mb-12" data-aos="fade-up" data-aos-delay="300">
            {regiones.map((region) => (
                <div class="flex items-center gap-2 bg-white/5 border border-white/10 rounded-lg px-4 py-3 hover:border-[#FFDF20]/40 hover:bg-white/8 transition-all duration-300">
                    <svg class="w-4 h-4 text-[#FFDF20] shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                    <span class="text-white/80 text-sm font-medium">{region}</span>
                </div>
            ))}
        </div>

        <div class="text-center" data-aos="fade-up" data-aos-delay="400">
            <a href="#contacto" class="inline-flex items-center gap-2 border-2 border-[#FFDF20] text-[#FFDF20] font-bold text-sm uppercase tracking-widest px-8 py-3.5 rounded-lg transition-all duration-300 hover:bg-[#FFDF20] hover:text-[#1a1a1a] hover:shadow-[0_0_25px_rgba(255,223,32,0.25)]">
                ¡Llegamos donde tu proyecto nos necesite!
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </a>
        </div>
    </div>
</section>